{
  "name": "@onecx/react-utils",
  "version": "8.4.2",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/onecx/onecx-portal-ui-libs"
  },
  "type": "module",
  "main": "./lib/index.cjs",
  "module": "./lib/index.mjs",
  "types": "./lib/index.d.ts",
  "typings": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.mjs",
      "require": "./lib/index.cjs",
      "default": "./lib/index.mjs"
    },
    "./styling": {
      "types": "./lib/styling/primeReact/index.d.ts",
      "import": "./lib/styling.mjs",
      "require": "./lib/styling.cjs",
      "default": "./lib/styling.mjs"
    },
    "./utils": {
      "types": "./lib/utils/index.d.ts",
      "import": "./lib/utils.mjs",
      "require": "./lib/utils.cjs",
      "default": "./lib/utils.mjs"
    },
    "./guards": {
      "types": "./lib/guards/index.d.ts",
      "import": "./lib/guards.mjs",
      "require": "./lib/guards.cjs",
      "default": "./lib/guards.mjs"
    },
    "./prime-base-theme": {
      "types": "./lib/styling/primeReact/styles.d.ts",
      "import": "./lib/prime-base-theme.mjs",
      "require": "./lib/prime-base-theme.cjs",
      "default": "./lib/prime-base-theme.mjs"
    },
    "./package.json": "./package.json"
  },
  "peerDependencies": {
    "@onecx/accelerator": "^8.4.2",
    "@onecx/integration-interface": "^8.4.2",
    "@onecx/react-integration-interface": "^8.4.2",
    "@onecx/react-webcomponents": "^8.4.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "primereact": "10.9.7",
    "react-i18next": "^16.5.4",
    "react-router": "^7.13.0"
  },
  "dependencies": {},
  "publishConfig": {
    "access": "public"
  }
}

{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "bundler",
    "module": "preserve",
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2022",
    "lib": ["es2022", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@onecx/accelerator": ["libs/accelerator/src/index.ts"],
      "@onecx/angular-accelerator": ["libs/angular-accelerator/src/index.ts"],
      "@onecx/angular-accelerator/testing": ["libs/angular-accelerator/testing/index.ts"],
      "@onecx/angular-auth": ["libs/angular-auth/src/index.ts"],
      "@onecx/angular-integration-interface": ["libs/angular-integration-interface/src/index.ts"],
      "@onecx/angular-integration-interface/mocks": ["libs/angular-integration-interface/mocks/index.ts"],
      "@onecx/angular-remote-components": ["libs/angular-remote-components/src/index.ts"],
      "@onecx/angular-remote-components/mocks": ["libs/angular-remote-components/mocks/index.ts"],
      "@onecx/angular-remote-components/testing": ["libs/angular-remote-components/testing/index.ts"],
      "@onecx/angular-standalone-shell": ["libs/angular-standalone-shell/src/index.ts"],
      "@onecx/angular-testing": ["libs/angular-testing/src/index.ts"],
      "@onecx/angular-utils": ["libs/angular-utils/src/index.ts"],
      "@onecx/angular-utils/cdk": ["libs/angular-utils/cdk/src/index.ts"],
      "@onecx/angular-utils/guards": ["libs/angular-utils/guards/index.ts"],
      "@onecx/angular-utils/mocks": ["libs/angular-utils/mocks/index.ts"],
      "@onecx/angular-utils/style": ["libs/angular-utils/style/src/index.ts"],
      "@onecx/angular-utils/theme/primeng": ["libs/angular-utils/theme/primeng/src/index.ts"],
      "@onecx/angular-webcomponents": ["libs/angular-webcomponents/src/index.ts"],
      "@onecx/integration-interface": ["libs/integration-interface/src/index.ts"],
      "@onecx/ngrx-accelerator": ["libs/ngrx-accelerator/src/index.ts"],
      "@onecx/release": ["tools/release/src/index.ts"],
      "@onecx/angular-linter-rules": ["libs/angular-linter-rules/src/index.ts"],
      "@onecx/ngrx-linter-rules": ["libs/ngrx-linter-rules/src/index.ts"],
      "@onecx/shell-auth": ["libs/shell-auth/src/index.ts"],
      "@onecx/react-auth": ["libs/react-auth/src/index.ts"],
      "@onecx/react-integration-interface": ["libs/react-integration-interface/src/index.ts"],
      "@onecx/react-integration-interface/mocks": ["libs/react-integration-interface/src/lib/mocks/index.ts"],
      "@onecx/react-remote-components": ["libs/react-remote-components/src/index.ts"],
      "@onecx/react-webcomponents": ["libs/react-webcomponents/src/index.ts"],
      "@onecx/react-utils": ["libs/react-utils/src/lib/index.ts"],
      "@onecx/react-utils/routing": ["libs/react-utils/src/lib/routing/index.tsx"],
      "@onecx/react-utils/styling": ["libs/react-utils/src/lib/styling/index.ts"],
      "@onecx/react-utils/theme": ["libs/react-utils/src/lib/styling/theme/index.ts"],
      "@onecx/react-utils/utils": ["libs/react-utils/src/lib/utils/index.ts"],
      "@onecx/build-utils": ["libs/build-utils/src/index.ts"]
